# 🔴 必填
# 智谱 API Key（驱动全部 AI 推理，智谱AI开放平台 获取）
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# 🟡 建议填写
# Healthchecks.io UUID（免费，流水线崩了发告警到手机/邮箱）
# 去 https://healthchecks.io 注册 → 创建 check → 复制 UUID
HEALTHCHECK_UUID=your_uuid_here

# 🟢 可选
OBSIDIAN_VAULT_PATH="G:/ai软件/obsidian/ai新闻"   # Obsidian vault 根目录
TESSERACT_PATH="C:/Program Files/Tesseract-OCR/tesseract.exe"  # Tesseract 路径
BAIDU_APP_ID=xxx                 # 百度翻译 APPID
BAIDU_SECRET_KEY=xxx             # 百度翻译密钥
TAVILY_API_KEY=xxx               # Tavily 搜索（备胎）
BAIDU_API_KEY=xxx                # 百度 OCR API Key
BAIDU_SECRET_KEY=xxx             # 百度 OCR Secret Key
N8N_WEBHOOK_URL=xxx              # n8n Webhook URL（可选）
# HF_ENDPOINT=https://hf-mirror.com  # HuggingFace 镜像（国内加速）
